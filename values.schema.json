{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["clusterName", "region", "sshKeyName", "worker"],
  "properties": {
    "clusterName": {
      "type": "string",
      "minLength": 1
    },
    "region": {
      "type": "string",
      "minLength": 1
    },
    "sshKeyName": {
      "type": "string",
      "minLength": 1
    },
    "worker": {
      "type": "object",
      "required": ["serverType"],
      "properties": {
        "serverType": {
          "type": "string",
          "minLength": 1
        },
        "imageName": {
          "type": "string"
        },
        "replicas": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "etcd": {
      "type": "object",
      "properties": {
        "autoDeletePVCs": {
          "type": "boolean"
        }
      }
    },
    "k0s": {
      "type": "object",
      "properties": {
        "version": {
          "type": "string",
          "pattern": "^v\\d+\\.\\d+\\.\\d+\\+k0s\\.\\d+$"
        }
      }
    },
    "ingress": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "apiHost": { "type": "string" },
        "konnectivityHost": { "type": "string" },
        "className": { "type": "string" },
        "port": { "type": "integer" },
        "annotations": { "type": "object" }
      },
      "if": {
        "properties": { "enabled": { "const": true } }
      },
      "then": {
        "required": ["apiHost", "konnectivityHost"],
        "properties": {
          "apiHost": { "minLength": 1 },
          "konnectivityHost": { "minLength": 1 }
        }
      }
    }
  }
}
